# Salin isi relevan ke backend\.env di server 192.168.32.15

APP_NAME="Work Order APS"
APP_ENV=production
APP_DEBUG=false
APP_URL=http://192.168.32.15:8000

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=wo_aps
DB_USERNAME=root
DB_PASSWORD=

# Frontend client (3000=e-letter, 3001=terpakai → default WO APS: 3002)
CORS_ALLOWED_ORIGINS=http://192.168.32.15:3002,http://localhost:3002

SANCTUM_STATEFUL_DOMAINS=192.168.32.15:3002,localhost:3002

WO_LABOR_HOURLY_RATE=150000
WO_STANDARD_HOURS_PER_DAY=8
